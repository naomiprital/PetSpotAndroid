<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <include
        android:id="@+id/fact_card_include"
        layout="@layout/layout_pet_fact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/filter_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/fact_card_include">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <EditText
                android:id="@+id/search_edit_text"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_rounded_box"
                android:drawableStart="@drawable/ic_search_filled"
                android:drawablePadding="12dp"
                android:hint="@string/search_location_or_description"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:textSize="14sp"
                android:textColorHint="@color/gray_text"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/dropdown_type"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_rounded_box"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                app:drawableEndCompat="@drawable/ic_arrow_down"
                app:layout_constraintTop_toBottomOf="@id/search_edit_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/dropdown_animal"
                app:layout_constraintHorizontal_weight="1" />

            <TextView
                android:id="@+id/dropdown_animal"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_box"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                app:drawableEndCompat="@drawable/ic_arrow_down"
                app:layout_constraintTop_toBottomOf="@id/search_edit_text"
                app:layout_constraintStart_toEndOf="@id/dropdown_type"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <TextView
                android:id="@+id/dropdown_sort"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_box"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                app:drawableEndCompat="@drawable/ic_arrow_down"
                app:layout_constraintTop_toBottomOf="@id/dropdown_type"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="@id/dropdown_type" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/posts_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="52dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/filter_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/empty_state_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_pets_found_matching_your_filters"
        android:textColor="@color/gray_text"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/posts_recycler_view"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_post_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/add_post" />

</androidx.constraintlayout.widget.ConstraintLayout>